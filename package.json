{
  "name": "share-html",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "homepage": "https://sharehtml.zhenjia.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifeodyssey/share-html.git"
  },
  "bugs": {
    "url": "https://github.com/lifeodyssey/share-html/issues"
  },
  "scripts": {
    "dev": "vite build --mode development && wrangler dev",
    "dev:client": "vite --host 127.0.0.1",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "build": "vite build && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "cf:whoami": "wrangler whoami",
    "cf:types": "wrangler types"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@supabase/supabase-js": "^2.86.2",
    "vite": "^7.2.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.94.0"
  }
}
