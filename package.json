{
  "name": "share-html",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "homepage": "https://sharehtml.zhenjia.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifeodyssey/share-html.git"
  },
  "bugs": {
    "url": "https://github.com/lifeodyssey/share-html/issues"
  },
  "scripts": {
    "dev": "vite build --mode development && wrangler dev",
    "dev:client": "vite --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "cf:whoami": "wrangler whoami",
    "cf:types": "wrangler types"
  },
  "dependencies": {
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@supabase/supabase-js": "^2.86.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.12",
    "@vitejs/plugin-react": "^5.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.3.0",
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.94.0"
  }
